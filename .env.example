# Used by docker-compose.yml to build the correct URLs for wherever you
# deploy this (a server IP, a domain name, or localhost for local dev).
#
# Copy this to ".env" (same folder as docker-compose.yml) and set it to
# your server's actual address. docker-compose reads ".env" automatically.

SERVER_HOST=localhost

# Set to False once you're not just testing on a trusted local network.
DEBUG=True

# Email: leave EMAIL_BACKEND unset (or console) during local/LAN testing --
# verification codes print to `docker compose logs -f backend` instead of
# being emailed. Fill these in with your institute's SMTP details to send
# real email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@seismology.uz
