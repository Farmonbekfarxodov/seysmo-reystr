# Django
DEBUG=True
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=seismology_registry
DB_USER=seismology_registry
DB_PASSWORD=seismology_registry
DB_HOST=localhost
DB_PORT=5432

# CORS / frontend
FRONTEND_ORIGIN=http://localhost:5173

# Email (console backend prints codes to the runserver terminal in development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@seismology-institute.local

# JWT lifetimes
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# Optional: restrict registration to a corporate email domain, e.g. "seismology.uz".
# Leave blank to allow any email domain.
ALLOWED_EMAIL_DOMAIN=
